        "\n",
        "ax.set_axisbelow(True)\n",
        "plt.grid(color='gray', linestyle='dashed')\n",
        "plt.gca().set_aspect('equal', adjustable='box')\n",
        "\n",
        "plt.show()"
      ]
    },
