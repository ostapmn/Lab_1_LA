     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Scaling matrix is\n",
      "[[1.  0. ]\n",
      " [0.  0.5]]\n"
     ]
    }
   ],
   "source": [
    "##### YOUR CODE STARTS #####\n",
    "def get_scaling_matrix(scale_factor_x, scale_factor_y):\n",
    "  return np.array([[scale_factor_x, 0],\n",
    "                   [0, scale_factor_y]], dtype=np.float32)\n",
    "\n",
    "M2 = get_scaling_matrix(1, 0.5)\n",
    "\n",
    "##### YOUR CODE ENDS #####\n",
    "print(\"Scaling matrix is\")\n",
    "print(M2)"
   ]
  },
