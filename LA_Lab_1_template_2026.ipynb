        "\n",
        "    Returns:\n",
        "    - x (list): Solution vector containing the restored pixel values.\n",
        "    \"\"\"\n",
        "    if method == 'numpy':\n",
        "        return np.linalg.solve(A, b)\n",
        "    else:\n",
        "        n = len(A)\n",
        "        x = [0] * n\n",
        "\n",
        "        ### YOUR CODE SOLUTION START\n",
