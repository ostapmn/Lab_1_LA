        "# Solve the linear system using Gaussian elimination or NumPy\n",
        "def solve_linear_system(A, b, method='numpy'):\n",
        "    \"\"\"\n",
        "    Solves the linear system Ax = B.\n",
        "\n",
        "    Parameters:\n",
        "    - A (list of lists): Coefficient matrix.\n",
        "    - b (list): Right-hand side vector.\n",
